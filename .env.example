# ===========================================
# DICloak 客服助手 - 环境变量配置
# ===========================================

# Supabase 数据库配置
COZE_SUPABASE_URL=你的Supabase项目URL
COZE_SUPABASE_ANON_KEY=你的Supabase ANON KEY

# Coze Bot API 配置
COZE_BOT_ID=你的Bot ID
COZE_API_TOKEN=你的Coze API Token
COZE_API_ENDPOINT=https://api.coze.cn

# 可选：其他 AI API（如果切换 AI 平台）
# OPENAI_API_KEY=你的OpenAI API Key
# ANTHROPIC_API_KEY=你的Claude API Key
